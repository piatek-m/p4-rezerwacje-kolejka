<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="OfficeReservations.Views.ClientDataPage"
             Title="Dane klienta">

    <ScrollView>
        <VerticalStackLayout Padding="20"
                             Spacing="8">

            <Label Text="Podaj swoje dane"
                   FontSize="24"
                   FontAttributes="Bold"/>

            <Label Text="Pola oznaczone * są wymagane"
                   FontSize="12"
                   TextColor="Gray"/>

            <!-- Dynamic fields -->
            <VerticalStackLayout x:Name="FormContainer"
                                 Spacing="12"/>

            <Button Text="Dalej"
                    Command="{Binding ProceedCommand}"
                    HorizontalOptions="Fill"
                    Margin="0,16,0,0"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>