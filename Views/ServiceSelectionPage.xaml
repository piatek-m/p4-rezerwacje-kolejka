<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:OfficeReservations.ViewModels"
             x:Class="OfficeReservations.Views.ServiceSelectionPage"
             Title="Wybór usługi">

    <VerticalStackLayout Padding="20"
                         Spacing="16">

        <Label Text="Wybierz usługę z listy poniżej"
               FontSize="18"
               TextColor="Gray"/>

        <!-- Grouped Services list -->
        <CollectionView ItemsSource="{Binding Departments}"
                        IsGrouped="True"
                        SelectionMode="Single"
                        SelectedItem="{Binding SelectedService}"
                        HeightRequest="400">

            <!-- Department name/Group header -->
            <CollectionView.GroupHeaderTemplate>
                <DataTemplate>
                    <VerticalStackLayout>
                        <Label Text="{Binding OfficeName}"
                               FontSize="11"
                               TextColor="Gray"
                               Margin="0,12,0,0"/>
                        <Label Text="{Binding Name}"
                               FontSize="15"
                               FontAttributes="Bold"
                               TextColor="#2c3e50"/>
                        <BoxView HeightRequest="1"
                                 Color="#bdc3c7"
                                 Margin="0,4,0,0"/>
                    </VerticalStackLayout>
                </DataTemplate>
            </CollectionView.GroupHeaderTemplate>

            <!-- Service in grid -->
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Grid Padding="8,10"
                          ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0"
                               Text="{Binding Name}"
                               FontSize="14"
                               VerticalOptions="Center"/>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>

        <Button Text="Dalej"
                Command="{Binding ProceedCommand}"
                HorizontalOptions="Fill"
                Margin="0,8,0,0"/>

    </VerticalStackLayout>
</ContentPage>