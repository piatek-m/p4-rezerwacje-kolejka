<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="OfficeReservations.Views.MainPage"
             Title="System kolejkowy">

    <VerticalStackLayout Padding="40"
                         Spacing="20"
                         VerticalOptions="Center">

        <Label Text="System kolejkowy urzędu"
               FontSize="28"
               FontAttributes="Bold"
               HorizontalTextAlignment="Center"/>

        <Label Text="Wybierz opcję"
               FontSize="16"
               TextColor="Gray"
               HorizontalTextAlignment="Center"/>

        <Button Text="Zarezerwuj wizytę"
                FontSize="18"
                HeightRequest="60"
                Clicked="OnReservationClicked"/>

        <Button Text="Dołącz do kolejki"
                FontSize="18"
                HeightRequest="60"
                Clicked="OnJoinQueueClicked"/>

    </VerticalStackLayout>
</ContentPage>