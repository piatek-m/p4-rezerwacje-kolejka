<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="OfficeReservations.Views.SummaryPage"
             Title="Potwierdzenie rezerwacji">
    <ScrollView>
        <VerticalStackLayout Padding="20"
                             Spacing="12">

            <Label Text="Podsumowanie"
                   FontSize="24"
                   FontAttributes="Bold"/>

            <Label Text="Usługa"
                   FontSize="12"
                   TextColor="Gray"/>
            <Label Text="{Binding SelectedService.Name}"
                   FontSize="16"/>

            <Label Text="Dział"
                   FontSize="12"
                   TextColor="Gray"/>
            <Label Text="{Binding SelectedService.DepartmentName}"
                   FontSize="16"/>

            <Label Text="Termin"
                   FontSize="12"
                   TextColor="Gray"/>
            <Label Text="{Binding SelectedSlot, StringFormat='{0:dd MMMM yyyy, HH:mm}'}"
                   FontSize="16"/>

            <Label Text="Imię i nazwisko"
                   FontSize="12"
                   TextColor="Gray"/>
            <Label FontSize="16">
                <Label.FormattedText>
                    <FormattedString>
                        <Span Text="{Binding ClientData.FirstName}"/>
                        <Span Text=" "/>
                        <Span Text="{Binding ClientData.LastName}"/>
                    </FormattedString>
                </Label.FormattedText>
            </Label>

            <Label Text="PESEL"
                   FontSize="12"
                   TextColor="Gray"/>
            <Label Text="{Binding ClientData.Pesel}"
                   FontSize="16"/>

            <Label Text="Email"
                   FontSize="12"
                   TextColor="Gray"/>
            <Label Text="{Binding EmailDisplay}"
                   FontSize="16"/>

            <Label Text="Telefon"
                   FontSize="12"
                   TextColor="Gray"/>
            <Label Text="{Binding PhoneDisplay}"
                   FontSize="16"/>

            <BoxView HeightRequest="1"
                     Color="#bdc3c7"
                     Margin="0,8"/>

            <VerticalStackLayout IsVisible="{Binding IsConfirmed}"
                                 Spacing="8">
                <Label Text="Twój kod rezerwacji:"
                       FontSize="16"
                       FontAttributes="Bold"/>
                <Label Text="{Binding ConfirmationCode}"
                       FontSize="36"
                       FontAttributes="Bold"
                       HorizontalOptions="Center"
                       TextColor="#2c3e50"/>
                <Label Text="Zapisz kod, będzie potrzebny przy dołączaniu do kolejki"
                       FontSize="12"
                       TextColor="Gray"
                       HorizontalTextAlignment="Center"/>
            </VerticalStackLayout>

            <Button Text="Potwierdź rezerwację"
                    Command="{Binding ConfirmCommand}"
                    HorizontalOptions="Fill"
                    Margin="0,8,0,0"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
